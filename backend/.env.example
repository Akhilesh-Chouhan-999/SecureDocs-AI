# SecureDoc AI - Backend Environment Configuration

# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=5000
HOST=localhost

# ========================================
# Database Configuration (MongoDB)
# ========================================
MONGODB_URI=mongodb://localhost:27017/securedoc_ai
MONGODB_USER=your_mongodb_user
MONGODB_PASSWORD=your_mongodb_password

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=7d

# ========================================
# LLM Provider Configuration
# ========================================
# Choose one: OPENAI_API_KEY or GEMINI_API_KEY
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4
GEMINI_API_KEY=your-gemini-api-key-here

# ========================================
# Vector Database (ChromaDB)
# ========================================
CHROMA_DB_URL=http://localhost:8000
CHROMA_DB_API_KEY=optional-api-key

# ========================================
# File Upload Configuration
# ========================================
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# ========================================
# Cache Configuration (Redis)
# ========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=optional-redis-password

# ========================================
# Email Configuration (Optional)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@securedoc.ai

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ========================================
# Application Features
# ========================================
ENABLE_OCR=true
ENABLE_RAG=true
ENABLE_JOB_QUEUE=true

# ========================================
# Frontend URL (for CORS)
# ========================================
FRONTEND_URL=http://localhost:3000

# ========================================
# Optional: Third-party Services
# ========================================
SENTRY_DSN=optional-sentry-dsn
DATADOG_API_KEY=optional-datadog-key
