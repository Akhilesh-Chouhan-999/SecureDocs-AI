{
  "name": "securedoc-backend",
  "version": "1.0.0",
  "description": "SecureDoc AI - Modular Backend with SOLID Principles",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/server.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --detectOpenHandles --passWithNoTests",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "lint": "eslint src/ --fix",
    "format": "prettier --write src/",
    "migrate:up": "node src/scripts/migrate.js up",
    "migrate:down": "node src/scripts/migrate.js down",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@langchain/community": "^0.0.57",
    "@langchain/core": "^0.1.62",
    "@langchain/google-genai": "^0.0.13",
    "@langchain/openai": "^0.0.28",
    "@sentry/node": "^7.77.0",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.5",
    "chromadb": "^3.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "joi": "^17.11.0",
    "jsdoc": "^4.0.5",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.1.37",
    "languagedetect": "^2.0.0",
    "lodash": "^4.17.21",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.8",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "tesseract.js": "^5.0.4",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "cross-env": "^10.1.0",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.4",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
